# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit a real .env — it contains secrets.
# ─────────────────────────────────────────────────────────────

# Prisma Accelerate connection string (prod) OR a direct MySQL URL (local dev).
# Local dev example: mysql://root:root@localhost:3306/edu
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_KEY_HERE"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 48
# REQUIRED in production — the app refuses to start without it there.
JWT_SECRET="change-me-to-a-long-random-string"

# Base URL used to build password-reset links (no trailing slash).
APP_BASE_URL="http://localhost:3000"

# MailerSend (optional). If absent, reset links are logged to the server
# console in dev instead of being emailed.
MAILERSEND_API_KEY=""
SENDER_DOMAIN="test-xxxxxxxx.mlsender.net"

# Admin bootstrap (used by: npm run seed:admin)
ADMIN_EMAIL="admin@ku.ac.th"
ADMIN_PASSWORD="ChangeMe123!"

# Demo seed password (used by: npm run seed:demo)
DEMO_PASSWORD="demo1234"
